<%
  field_class = "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm"
  label_class = "block text-sm font-medium text-ink mb-1"
%>

<%= form_with model: [:admin, totem], class: "space-y-5 max-w-lg" do |f| %>
  <% if totem.errors.any? %>
    <div class="bg-ember/10 border border-ember/30 rounded-lg p-4">
      <p class="text-ember font-medium text-sm mb-1"><%= pluralize(totem.errors.count, "error") %> prevented this totem from being saved:</p>
      <ul class="list-disc list-inside text-sm text-ember space-y-0.5">
        <% totem.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Name", class: label_class %>
    <%= f.text_field :name, required: true, placeholder: "e.g. Waterfront North", class: field_class %>
  </div>

  <div>
    <%= f.label :location, "Location", class: label_class %>
    <%= f.text_field :location, required: true, placeholder: "e.g. Waterfront Park", class: field_class %>
  </div>

  <div>
    <%= f.label :sublocation, "Sub-location", class: label_class %>
    <p class="text-xs text-stone mb-1">Optional. Shown after the park name.</p>
    <%= f.text_field :sublocation, placeholder: "e.g. Pier entry", class: field_class %>
  </div>

  <fieldset>
    <legend class="<%= label_class %>">Status</legend>
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :active, class: "rounded border-stone/40 text-ember focus:ring-ember" %>
      <span class="text-sm text-ink">Active</span>
    </label>
  </fieldset>

  <div class="flex items-center gap-3 pt-2 border-t border-stone/20">
    <%= f.submit totem.new_record? ? "Create totem" : "Save changes",
          class: "bg-ember text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
    <%= link_to "Cancel", admin_totems_path, class: "text-sm text-stone hover:text-ink transition" %>
  </div>
<% end %>
