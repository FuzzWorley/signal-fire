<% content_for :title, "Admin Sign In — Signal Fire" %>

<div class="min-h-screen bg-ink flex flex-col items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <h1 class="font-serif text-4xl text-white mb-1">Signal Fire</h1>
      <p class="text-stone/50 text-xs font-mono uppercase tracking-widest">Admin</p>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
      <p class="font-mono text-[10px] uppercase tracking-widest text-stone/50 mb-3">Founders Only</p>
      <h2 class="font-serif text-2xl text-white mb-6">Sign in.</h2>

      <% if flash[:alert] %>
        <div class="bg-ember/20 border border-ember/40 rounded-lg px-4 py-3 mb-5">
          <p class="text-ember text-sm"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-white/70 mb-1" %>
          <%= f.email_field :email,
                required: true,
                autocomplete: "email",
                placeholder: "you@example.com",
                class: "w-full px-3 py-2 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/30 focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
        </div>

        <div>
          <%= f.label :password, "Password", class: "block text-sm font-medium text-white/70 mb-1" %>
          <%= f.password_field :password,
                required: true,
                autocomplete: "current-password",
                class: "w-full px-3 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
        </div>

        <%= f.submit "Sign in",
              class: "w-full bg-ember text-white font-semibold py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer mt-2" %>
      <% end %>
    </div>
  </div>
</div>
