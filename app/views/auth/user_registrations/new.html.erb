<% content_for :title, "Join Signal Fire" %>

<div class="min-h-screen bg-[#f2f0d9] flex flex-col items-center justify-center px-4" data-controller="account-signup">
  <div class="w-full max-w-sm bg-white rounded-2xl px-6 py-8">
    <h1 class="font-serif text-2xl text-[#1a1a12] mb-1">Join Signal Fire</h1>
    <p class="text-sm text-[#867a60] mb-6">We'll email you when our native app launches in the coming weeks.</p>

    <% if flash[:notice] %>
      <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm mb-4" role="status">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <div id="account-signup-form-container">
      <%= render "shared/account_signup_form", user: @user %>
    </div>

    <p class="text-center text-xs text-[#867a60] mt-4">
      Already have an account? <%= link_to "Sign in", sign_in_path, class: "underline hover:text-[#1a1a12]" %>
    </p>
  </div>
</div>
