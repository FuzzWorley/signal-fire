<% content_for :title, "Sign in — Signal Fire" %>

<div class="min-h-screen bg-[#f2f0d9] flex flex-col items-center justify-center px-4">
  <div class="w-full max-w-sm bg-white rounded-2xl px-6 py-8">
    <h1 class="font-serif text-2xl text-[#1a1a12] mb-1">Sign in</h1>
    <p class="text-sm text-[#867a60] mb-6">Welcome back.</p>

    <% if flash[:alert] %>
      <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm mb-4" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: sign_in_path do |f| %>
      <div class="space-y-3 mb-4">
        <div>
          <%= label_tag :email, "Email address", class: "sr-only" %>
          <%= email_field_tag :email, nil,
                placeholder: "you@email.com",
                required: true,
                autocomplete: "email",
                class: "w-full border border-[#867a60]/40 bg-white rounded-lg px-4 py-3 text-[#1a1a12] placeholder-[#867a60]/60 focus:outline-none focus:ring-2 focus:ring-[#e24820] focus:border-transparent" %>
        </div>
        <div>
          <%= label_tag :password, "Password", class: "sr-only" %>
          <%= password_field_tag :password, nil,
                placeholder: "Password",
                required: true,
                autocomplete: "current-password",
                class: "w-full border border-[#867a60]/40 bg-white rounded-lg px-4 py-3 text-[#1a1a12] placeholder-[#867a60]/60 focus:outline-none focus:ring-2 focus:ring-[#e24820] focus:border-transparent" %>
        </div>
      </div>

      <%= submit_tag "Sign in",
            class: "w-full bg-[#e24820] hover:bg-[#c43a18] text-white font-medium rounded-lg px-4 py-3 cursor-pointer transition-colors" %>
    <% end %>

    <p class="text-center text-xs text-[#867a60] mt-3">
      <%= link_to "or email me a magic link instead", sign_in_magic_link_path, class: "underline hover:text-[#1a1a12]" %>
    </p>

    <p class="text-center text-xs text-[#867a60] mt-4">
      Don't have an account? <%= link_to "Join Signal Fire", sign_up_path, class: "underline hover:text-[#1a1a12]" %>
    </p>
  </div>
</div>
