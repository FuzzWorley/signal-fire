<% content_for :title, "Checked in!" %>

<div class="min-h-screen bg-[#f2f0d9] flex flex-col items-center justify-center px-4 text-center">
  <%# Orange check circle %>
  <div class="w-20 h-20 rounded-full border-2 border-[#e24820] flex items-center justify-center mb-8">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#e24820]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
  </div>

  <h1 class="font-serif text-3xl text-[#1a1a12] mb-2">You're checked in.</h1>
  <p class="text-[#867a60] mb-8">
    <%= @event.title %>
    <% if @event.window_state == :happening_now %>
      · happening now
    <% elsif @event.window_state == :starting_soon %>
      · starting soon
    <% elsif @event.window_state == :just_ended %>
      · just ended
    <% end %>
  </p>

  <div class="w-full max-w-xs border-t border-[#867a60]/20 pt-8 mb-6">
    <p class="font-medium text-[#1a1a12] mb-1 text-left">Get the app for more</p>
    <p class="text-sm text-[#867a60] mb-5 text-left">
      Keep a personal check-in history, subscribe to hosts, and get notified when events go live.
    </p>
    <div class="flex gap-3">
      <a href="#"
         class="flex-1 text-center border border-[#867a60]/40 rounded-lg px-3 py-3 hover:border-[#867a60] transition-colors">
        <span class="block text-xs text-[#867a60]">Download on the</span>
        <span class="block text-sm font-semibold text-[#1a1a12]">App Store</span>
      </a>
      <a href="#"
         class="flex-1 text-center border border-[#867a60]/40 rounded-lg px-3 py-3 hover:border-[#867a60] transition-colors">
        <span class="block text-xs text-[#867a60]">Get it on</span>
        <span class="block text-sm font-semibold text-[#1a1a12]">Google Play</span>
      </a>
    </div>
  </div>

  <%= link_to "Not now, back to board",
        totem_board_path(@totem.slug),
        class: "text-sm text-[#867a60] underline" %>
</div>
