<%= form_with model: [:host, event], class: "space-y-6" do |f| %>
  <% if event.errors.any? %>
    <div class="bg-ember/10 border border-ember/30 rounded-lg p-4">
      <p class="text-ember font-medium text-sm mb-1"><%= pluralize(event.errors.count, "error") %> prevented this event from being saved:</p>
      <ul class="list-disc list-inside text-sm text-ember space-y-0.5">
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title %>
  <div>
    <%= f.label :title, "Title", class: "block text-sm font-medium text-ink mb-1" %>
    <%= f.text_field :title,
          required: true,
          placeholder: "e.g. Saturday Long Run",
          class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
  </div>

  <%# Totem %>
  <div>
    <%= f.label :totem_id, "Totem", class: "block text-sm font-medium text-ink mb-1" %>
    <%= f.select :totem_id,
          @totems.map { |t| [t.name, t.id] },
          { prompt: "Select a totem" },
          required: true,
          class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
  </div>

  <%# Recurrence %>
  <fieldset>
    <legend class="block text-sm font-medium text-ink mb-2">Event type</legend>
    <div class="flex gap-4">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :recurrence_type, "one_time", class: "accent-ember" %>
        <span class="text-sm text-ink">One-time</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :recurrence_type, "weekly", class: "accent-ember" %>
        <span class="text-sm text-ink">Weekly (recurring)</span>
      </label>
    </div>
  </fieldset>

  <%# Start / end times %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :start_time, "Start time", class: "block text-sm font-medium text-ink mb-1" %>
      <%= f.datetime_local_field :start_time,
            required: true,
            value: event.start_time&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
    </div>
    <div>
      <%= f.label :end_time, "End time", class: "block text-sm font-medium text-ink mb-1" %>
      <%= f.datetime_local_field :end_time,
            required: true,
            value: event.end_time&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
    </div>
  </div>

  <%# Description %>
  <div>
    <%= f.label :description, "Description", class: "block text-sm font-medium text-ink mb-1" %>
    <%= f.text_area :description,
          rows: 3,
          placeholder: "What should people know about this event?",
          class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition resize-y" %>
  </div>

  <%# Community norms %>
  <div>
    <%= f.label :community_norms, "Community norms", class: "block text-sm font-medium text-ink mb-1" %>
    <p class="text-xs text-stone mb-1">Shown on the event page. Optional.</p>
    <%= f.text_area :community_norms,
          rows: 3,
          placeholder: "e.g. Be kind. No one gets left behind.",
          class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition resize-y" %>
  </div>

  <%# Chat platform + URL %>
  <div data-controller="chat-url">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= f.label :chat_platform, "Messaging platform", class: "block text-sm font-medium text-ink mb-1" %>
        <%= f.select :chat_platform,
              Event.chat_platforms.keys.map { |p| [p.humanize, p] },
              { prompt: "Select platform" },
              required: true,
              data: { "chat-url-target": "platform", action: "change->chat-url#validate" },
              class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :chat_url, "Group invite link", class: "block text-sm font-medium text-ink mb-1" %>
        <%= f.url_field :chat_url,
              required: true,
              placeholder: "https://...",
              data: { "chat-url-target": "url", action: "input->chat-url#validate" },
              class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
        <p data-chat-url-target="feedback" class="text-xs text-stone mt-1"></p>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit event.new_record? ? "Create event" : "Save changes",
          class: "bg-ember text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
    <%= link_to "Cancel", host_events_path, class: "text-sm text-stone hover:text-ink transition" %>
  </div>
<% end %>
