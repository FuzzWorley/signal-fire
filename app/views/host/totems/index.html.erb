<% content_for :title, "Totems — Signal Fire" %>

<div class="mb-6">
  <h1 class="font-serif text-3xl text-ink">Totems</h1>
  <p class="text-stone text-sm mt-1">Your assigned community spaces.</p>
</div>

<% if @totems.any? %>
  <div class="space-y-3">
    <% @totems.each do |totem| %>
      <div class="bg-white/60 border border-stone/20 rounded-xl px-5 py-4">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-medium text-ink"><%= totem.name %></p>
            <% if totem.location_description.present? %>
              <p class="text-sm text-stone mt-0.5"><%= totem.location_description %></p>
            <% end %>
          </div>
          <span class="font-mono text-[10px] uppercase tracking-widest text-stone/50 border border-stone/20 px-2 py-1 rounded shrink-0">
            <%= totem.slug %>
          </span>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="border border-dashed border-stone/30 rounded-xl p-10 text-center">
    <p class="text-stone text-sm">No totems assigned yet. Contact your admin.</p>
  </div>
<% end %>
