<% content_for :title, "About Signal Fire" %>

<div class="min-h-screen bg-[#f2f0d9] px-4 py-12 max-w-prose mx-auto">
  <p class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-2">Signal Fire</p>
  <h1 class="font-serif text-4xl text-[#1a1a12] mb-8">About</h1>

  <div class="space-y-4 text-[#1a1a12] leading-relaxed">
