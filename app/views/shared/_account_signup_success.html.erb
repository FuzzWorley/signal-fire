<div id="<%= container_id %>" class="text-center py-4">
  <% if via_password %>
    <p class="font-semibold text-[#1a1a12] mb-1">You're in!</p>
    <p class="text-sm text-[#867a60]">Welcome to Signal Fire. We'll email you when the app launches.</p>
  <% else %>
    <p class="font-semibold text-[#1a1a12] mb-1">Check your email!</p>
    <p class="text-sm text-[#867a60]">We sent you a link — click it to sign in.</p>
  <% end %>
</div>
