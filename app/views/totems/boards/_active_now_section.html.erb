<section aria-label="Active now">
  <h2 class="font-mono text-xs tracking-widest text-[#e24820] uppercase mb-3">● Active Now</h2>
  <div class="space-y-3">
    <% events.each do |event| %>
      <%= render "event_card", event: event, totem: @totem, active_now: true %>
    <% end %>
  </div>
</section>
