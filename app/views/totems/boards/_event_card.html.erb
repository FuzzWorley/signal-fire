<% state = event.window_state %>
<% occurrence = event.next_occurrence %>

<%= link_to totem_event_path(totem.slug, event.slug),
      class: "block rounded-lg border p-4 transition-colors #{active_now ? 'border-[#e24820] bg-[#fff7f5]' : 'border-[#867a60]/30 bg-white hover:border-[#867a60]'}" do %>
  <div class="flex items-start justify-between gap-2">
    <div class="flex-1 min-w-0">
      <h3 class="font-medium text-[#1a1a12] truncate"><%= event.title %></h3>
      <p class="text-sm text-[#867a60] mt-0.5">
        <%= occurrence.strftime("%-I:%M %p").downcase %>
        <% if event.weekly? %>
          <span class="font-mono text-xs ml-1">· weekly</span>
        <% end %>
      </p>
    </div>

    <% if active_now %>
      <% chip_label = case state
         when :happening_now  then "Now"
         when :starting_soon  then "Soon"
         when :just_ended     then "Just ended"
         end %>
      <% if chip_label %>
        <span class="shrink-0 font-mono text-xs bg-[#e24820] text-white px-2 py-1 rounded-full">
          <%= chip_label %>
        </span>
      <% end %>
    <% end %>
  </div>

  <% if event.description.present? %>
    <p class="mt-2 text-sm text-[#867a60] line-clamp-2"><%= event.description %></p>
  <% end %>
<% end %>
