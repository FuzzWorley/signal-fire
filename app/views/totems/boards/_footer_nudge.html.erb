<div class="fixed bottom-0 inset-x-0 bg-[#1a1a12] text-[#f2f0d9] px-4 py-4 flex items-center justify-between gap-3">
  <p class="text-sm flex-1">Get the app for event reminders</p>
  <div class="flex items-center gap-3 shrink-0">
    <%= link_to "Get app", "#", class: "bg-[#e24820] text-white font-medium rounded px-4 py-2 text-sm" %>
    <%= link_to "Dismiss",
          totem_board_path(@totem.slug, dismiss_footer: "1"),
