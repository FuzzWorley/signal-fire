<div class="fixed bottom-0 inset-x-0 bg-[#1a1a12] text-[#f2f0d9] px-4 py-3 flex items-center justify-between gap-3">
  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium leading-tight">Get the app</p>
    <p class="text-xs text-[#867a60] leading-tight">Subscribe + track your check-ins</p>
  </div>
  <div class="flex items-center gap-3 shrink-0">
    <button data-action="click->app-nudge#open"
            class="bg-[#e24820] text-white font-medium rounded px-4 py-2 text-sm">
      Install
    </button>
    <%= link_to "Dismiss",
          totem_board_path(@totem.slug, dismiss_footer: "1"),
          class: "text-[#867a60] text-sm",
          data: { turbo: false } %>
  </div>
</div>
