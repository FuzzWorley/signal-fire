<% content_for :title, "#{@event.title} · #{@totem.name}" %>

<div class="min-h-screen bg-[#f2f0d9]" data-controller="app-nudge">
  <header class="px-4 pt-6 pb-4 border-b border-[#867a60]/20">
    <%= link_to "‹ Back to board", totem_board_path(@totem.slug),
          class: "inline-flex items-center text-sm text-[#867a60] mb-4" %>

    <% if @event.cancelled? %>
      <%= render "cancelled_banner" %>
    <% else %>
      <%= render "window_chip", state: @window_state %>
    <% end %>

    <h1 class="font-serif text-2xl text-[#1a1a12] leading-tight mt-2"><%= @event.title %></h1>

    <p class="mt-2 text-sm text-[#867a60]">
      <% occurrence = @event.next_occurrence %>
      <% if @event.weekly? %>
        Every <%= occurrence.strftime("%A") %> · <%= occurrence.strftime("%-I:%M %p") %> – <%= @event.end_time.strftime("%-I:%M %p") %>
      <% else %>
        <%= occurrence.strftime("%A · %B %-d · %-I:%M %p") %>
      <% end %>
    </p>

    <p class="text-sm text-[#867a60] mt-0.5">
      <%= @totem.name %><% if @totem.location_description.present? %> · <%= @totem.location_description %><% end %>
    </p>
  </header>

  <main class="px-4 pt-6 pb-40 space-y-6">
    <% if @host_profile %>
      <section>
        <h2 class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-2">About the host</h2>
        <p class="text-[#1a1a12]">
          <strong><%= @host_profile.display_name %></strong>
          <% if @host_profile.blurb.present? %> — <%= @host_profile.blurb %><% end %>
        </p>
      </section>
    <% end %>

    <% if @event.description.present? %>
      <section>
        <h2 class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-2">Description</h2>
        <p class="text-[#1a1a12] leading-relaxed"><%= @event.description %></p>
      </section>
    <% end %>

    <% if @event.community_norms.present? %>
      <%= render "community_norms", norms: @event.community_norms %>
    <% end %>
  </main>

  <div class="fixed bottom-0 inset-x-0 bg-[#f2f0d9] border-t border-[#867a60]/20 px-4 py-4 space-y-3">
    <% if [:starting_soon, :happening_now, :just_ended].include?(@window_state) %>
      <%= render "check_in_button", event: @event, totem: @totem %>
    <% end %>

    <%= render "join_chat_button", event: @event %>

    <% unless @event.cancelled? %>
      <button data-action="click->app-nudge#open"
              class="block w-full text-center border border-[#867a60]/40 text-[#1a1a12] font-medium rounded-lg px-4 py-3 bg-transparent hover:border-[#867a60] transition-colors">
        Get notified about this group
      </button>
    <% end %>
  </div>

  <div class="fixed bottom-[calc(env(safe-area-inset-bottom,0px)+8rem)] inset-x-0 flex justify-center pointer-events-none">
    <%# spacer for app nudge sheet clearance %>
  </div>

  <%= render "shared/app_download_nudge" %>
</div>
